# PATHS
# -----
# `input`, `output`, `log`, and `benchmark` files are considered to be
# relative to the working directory (either the directory in which
# you have invoked Snakemake or whatever was specified for
# `--directory` or the `workdir:` directive).
#
# Any other directives (e.g. `conda:`, `include:`, `script:`, `notebook:`)
# consider paths to be relative to the Snakefile they are defined in.
#
# Use `workflow.source_path(file_path)` to do the following:
# (a) computes the correct path relative to the current Snakefile such
#     that the file can be accessed from any working directory, and
# (b) downloads remote files to a local cache:
DOCS_DIR:             "docs"
LOG_DIR:              "logs/rules"
MODULE_DIR:           "{{ package_name }}"
REPORTS_DIR:          "reports/"
REPORT_TEMPLATES_DIR: "reports/notebook_templates"

# Conda environment files for Snakemake rules
# Generated by pyproject2conda from the configuration in `pyproject.toml`
CONDA:
  PYPROJECT2CONDA_DIR:    "envs/pyproject2conda"
  LOCALIZED_DIR:          "envs/localized"
  PYTHON:                 "py312"
  DEFAULT_ENV:            "DEV"
  ENVS:
    DEV:                  "dev"
    # TODO-copier-etl Add dev environment for each extra
    CORE:                 "core"
    # TODO-copier-etl Add package environment for each extra
    NOTEBOOK:             "notebook"
    DOCS:                 "docs"

"""Localize a conda environment YAML file using ruamel.

This script adds a pip editable install of the project
root to the YAML produced by pyproject2conda. It is
meant to be executed via Snakemake.
"""

import re
import os
import sys
import time
from pathlib import Path
from typing import Any, Mapping, Sequence, TYPE_CHECKING, Union

from loguru import logger
from ruamel.yaml import YAML
from ruamel.yaml.comments import CommentedMap, CommentedSeq

if TYPE_CHECKING:  # pragma: no cover
    # For type checking only, when called as a `script:` in a Snakemake rule
    # the `snakemake` object is injected at the top of the script
    from snakemake.script import snakemake

GUIDANCE = (
    "The {{ package_name }} package needs to be available in `site-packages`.\n"
    "Normally installing with `pip install -e .` is enough, but this breaks\n"
    "when Snakemake creates a conda environment per rule.\n\n"
    "  - `localized.yml`   \u2192 local dev, hard-coded absolute path\n"
    "  - `production.yml`  \u2192 installs from GitHub\n"
)

CondaDep = Union[str, Mapping[str, Any]]


def _ensure_output_mtime_not_older_than_input(src: Path, dst: Path) -> None:
    """Keep output mtime newer than input when filesystem clocks jitter.

    Some virtualized or bridged filesystems (notably WSL-backed workflows) can
    produce tiny timestamp inversions when files are created in rapid succession.
    Build tools may then emit false "clock skew" diagnostics even though content
    generation was correct, so we defensively bump the output mtime only when
    ``dst`` appears older than ``src``.

    References:
    - https://github.com/microsoft/WSL/issues/10006
    - https://github.com/microsoft/WSL/issues/8318
    """
    src_mtime = src.stat().st_mtime
    dst_mtime = dst.stat().st_mtime
    if dst_mtime >= src_mtime:
        return

    safe_mtime = max(src_mtime, time.time()) + 1.0
    os.utime(dst, (safe_mtime, safe_mtime))
    logger.warning(
        "Adjusted output mtime to avoid filesystem clock skew: "
        f"dst ({dst_mtime:.6f}) < src ({src_mtime:.6f}); "
        f"set dst mtime to {safe_mtime:.6f}"
    )

    updated_dst_mtime = dst.stat().st_mtime
    if updated_dst_mtime >= src_mtime:
        return

    wait_seconds = max(src_mtime - time.time(), 0.0) + 1.0
    logger.warning(
        "Output mtime still older than input after adjustment; "
        f"sleeping {wait_seconds:.3f}s and retrying"
    )
    time.sleep(wait_seconds)

    fallback_mtime = max(src_mtime, time.time()) + 1.0
    os.utime(dst, (fallback_mtime, fallback_mtime))

    final_dst_mtime = dst.stat().st_mtime
    if final_dst_mtime < src_mtime:
        logger.warning(
            "Output mtime remains older than input after retry: "
            f"dst ({final_dst_mtime:.6f}) < src ({src_mtime:.6f})"
        )


def main(smk) -> None:  # type: ignore[no-untyped-def]

    # Parse Snakemake directives
    src = Path(smk.input.src)
    dst = Path(smk.output.dst)
    project_root = Path(smk.params.project_root)

    # Setup logging
    logger.remove()
    logger.add(smk.log.loguru)

    # Read source YAML file
    yaml = YAML()
    yaml.preserve_quotes = True
    env = yaml.load(src.read_text())
    if env is None:
        raise ValueError(f"Failed to load YAML from {src}")

    # Check for 'dependencies' key
    deps = env.get("dependencies")
    if deps is None or not isinstance(deps, list):
        raise ValueError("Environment YAML missing 'dependencies' list")

    # ------------------------------------------------------------------
    # Ensure *some* pip dependency requires version >= 23.
    # If a suitable requirement already exists, do nothing.
    # Otherwise, append "pip>=23".
    # ------------------------------------------------------------------
    def _has_sufficient_pip(dep_list: Sequence[CondaDep]) -> bool:
        """
        Return True if any dependency entry specifies pip with
        a major version >= 23 (e.g. ``pip>=25.1.1`` or ``pip==24.0``).
        Crude string parsing avoids an external packaging dependency.
        """
        for d in dep_list:
            if not (isinstance(d, str) and d.strip().lower().startswith("pip")):
                continue
            # Extract first numeric portion after the word 'pip'
            match = re.search(r"(\d+)(?:\.\d+)*", d)
            if match and int(match.group(1)) >= 23:
                return True
        return False

    if not _has_sufficient_pip(deps):
        deps.append("pip>=23")

    # Locate or create pip block
    pip_map: CommentedMap | None = None
    for item in deps:
        if isinstance(item, dict) and "pip" in item:
            pip_map = item
            break

    if pip_map is None:
        pip_map = CommentedMap()
        pip_map["pip"] = CommentedSeq()
        deps.append(pip_map)

    pip_list = pip_map["pip"]

    # Attach guidance comment to the *list item* so the dash
    # and comment stay on the same line.
    pip_comment = GUIDANCE.rstrip().replace("\n", "\n    ")
    pip_map.yaml_set_start_comment(pip_comment)

    # Add editable install entry if missing
    editable_entry = f"-e {project_root}"
    if editable_entry not in pip_list:
        pip_list.append(editable_entry)

    dst.parent.mkdir(parents=True, exist_ok=True)
    with dst.open("w") as fh:
        yaml.dump(env, fh)

    _ensure_output_mtime_not_older_than_input(src=src, dst=dst)

    logger.info(f"Localized {src} to {dst}")


if __name__ == "__main__":
    try:
        main(snakemake)
    except NameError:
        logger.error(
            "This script is designed to be run as part of a Snakemake workflow. "
            "Please run it through Snakemake."
        )
        sys.exit(0)

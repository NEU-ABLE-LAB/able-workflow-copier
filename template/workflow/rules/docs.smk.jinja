rule docs_serve_service:
    """
    Make and serve the documentation.
    NOTE: This rule is "blocking", and will not return until the server is stopped.
          This rule is only for development purposes.
    """
    localrule: True
    threads: 1
    input:
        # WORKFLOW_BASE is used here instead of workflow.source_path()
        # since workflow.source_path() cannot cache an entire directory
        # so instead just point to the mkdocs.yml file and assume the
        # worker has access to the entire directory
        mkdocs_yml=WORKFLOW_BASE / "../docs/mkdocs.yml",
        dag_svg=rules.dag_svg_all.input.svg,
    output:
        server=service("logs/services/{{ package_name }}-mkdocs.server"),
    log:
        stdout=LOG_DIR / "docs_serve" / "stdout.log",
        stderr=LOG_DIR / "docs_serve" / "stderr.log",
    conda:
        get_localized_conda(config["CONDA"]["ENVS"]["DOCS"])
    shell:
        """
        touch "{output.server}"
        exec 1>"{log.stdout}"
        exec 2>"{log.stderr}"

        # --- automatic cleanup ----------------------------------------------
        # Remove the server file on exit to stop the service
        # This is a simple way to ensure the service stops
        # when the Snakemake workflow is stopped or interrupted.
        # This is a workaround for the fact that Snakemake
        # does not automatically stop services when the workflow
        # is stopped or interrupted.
        cleanup() {% raw %}{{{% endraw %}
            echo "Stopping MkDocs"
            rm -f {output.server}
        {% raw %}}}{% endraw %}
        trap cleanup EXIT INT TERM HUP

        # --- launch mkdocs --------------------------------------------------
        export JUPYTER_PLATFORM_DIRS=1
        mkdocs serve \
          --config-file {input.mkdocs_yml}
        """

rule docs_serve:
    """
    Hold the `docs_serve_service` rule in a service
    so that it can be run in the background.
    """
    localrule: True
    input:
        rules.docs_serve_service.output.server,
    shell:
        """
        # This rule is a no-op, it just holds the service running
        echo "Serving {{ package_name }} documentation"
        echo "Press Ctrl+C to stop the server."
        tail -f /dev/null  # an infinite but lightweight wait
        echo "{{ package_name }} documentation server stopped"
        """

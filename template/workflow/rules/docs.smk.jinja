rule docs_build:
    """
    Build the documentation.

    input:
        mkdocs_yml: WORKFLOW_BASE is used here instead of workflow.source_path()
            since workflow.source_path() cannot cache an entire directory
            so instead just point to the mkdocs.yml file and assume the
            worker has access to the entire directory
        dag_svg: The DAG SVG generated by the `dag_svg` rule.

    output:
        site_dir: The directory where the built documentation will be placed.
    """
    localrule: True
    input:
        mkdocs_yml=WORKFLOW_BASE / "../docs/mkdocs.yml",
        dag_svg=rules.dag_svg_all.input.svg,
    output:
        site_dir=directory(Path(config["DOCS_SITE_DIR"]).resolve()),
    log:
        stdout=LOG_DIR / "docs_build" / "stdout.log",
        stderr=LOG_DIR / "docs_build" / "stderr.log",
    conda:
        get_localized_conda(config["CONDA"]["ENVS"]["DOCS"])
    shell:
        """
        exec 1>"{log.stdout}"
        exec 2>"{log.stderr}"
        export JUPYTER_PLATFORM_DIRS=1
        mkdocs build \
          --config-file {input.mkdocs_yml} \
          --site-dir {output.site_dir}
        """



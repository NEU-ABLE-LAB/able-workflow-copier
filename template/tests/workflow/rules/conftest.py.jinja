import shlex
import shutil
import subprocess
import sys
import textwrap
from pathlib import Path
from typing import List

import pytest
from loguru import logger


# --- Helpers ----------------------------------------------------------------
def _snakemake(workspace: Path, extra: List[str], verbose: bool = True) -> None:
    """Thin wrapper so the command line is only written once."""

    cmd = [
        "snakemake",
        "--show-failed-logs",
        *extra,
    ]

    logger.debug(f"Executing: {shlex.join(cmd)}")

    try:
        cp = subprocess.run(
            cmd,
            cwd=workspace,
            check=True,
            capture_output=True,
        )
    except subprocess.CalledProcessError as e:
        # If the command fails, print the output and raise an error
        sys.stderr.write(
            f"\n===== Snakemake Error stdout =====\n{e.stdout.decode('utf-8')}"
            f"\n===== Snakemake Error stderr =====\n{e.stderr.decode('utf-8')}\n"
        )
        raise

    # If the command fails, print the output and raise an error
    if cp.returncode:
        sys.stderr.write(
            f"\n===== Snakemake Return Code stdout =====\n{cp.stdout.decode('utf-8')}"
            f"\n===== Snakemake Return Code stderr =====\n{cp.stderr.decode('utf-8')}\n"
        )
        cp.check_returncode()

    # Only write output if verbose flag is True
    if verbose:
        sys.stdout.write(
            f"\n===== Snakemake Verbose stdout =====\n{cp.stdout.decode('utf-8')}"
            f"\n===== Snakemake Verbose stderr =====\n{cp.stderr.decode('utf-8')}\n"
        )


# --- Fixtures ---------------------------------------------------------------
@pytest.fixture(
    params=[
        # "proj_root",
        "workflow",
    ]
)
def workspace(
    tmp_path_factory: pytest.TempPathFactory,
    request: pytest.FixtureRequest,
) -> Path:
    """
    One disposable Snakemake working directory.

    The fixture is parameterised so every test is executed twice:

    `request.param` can be either:
    ─ `"proj_root"`: Snakefile at 〈tmp〉/Snakefile
    ─ `"workflow"`:  Snakefile at 〈tmp〉/workflow/Snakefile
    """
    snakefile_loc = request.param
    test_module = request.module.__name__
    basename = f"{test_module}_{snakefile_loc}"

    tmp_path = tmp_path_factory.mktemp(
        basename=basename,
        numbered=True,
    )
    logger.debug(f"Working in a temporary project root: {tmp_path}")

    repo_root = request.config.rootdir

    # Copy the repo’s config and profile
    shutil.copytree(repo_root / "config", tmp_path / "config")

    # Decide where the local Snakefile lives
    if snakefile_loc == "proj_root":
        snakefile_dir = tmp_path
        shutil.copytree(repo_root / "workflow" / "profiles", tmp_path / "profiles")
    elif snakefile_loc == "workflow":
        snakefile_dir = tmp_path / "workflow"
        snakefile_dir.mkdir()
        shutil.copytree(
            repo_root / "workflow" / "profiles", tmp_path / "workflow" / "profiles"
        )
    else:
        raise ValueError(f"Unknown location: {snakefile_loc}")

    # Minimal Snakefile that imports the real workflow
    (snakefile_dir / "Snakefile").write_text(
        textwrap.dedent(
            f"""\
        module {{ package_name }}:
            snakefile: "{repo_root / 'workflow' / 'Snakefile'}"
            config: config

        use rule * from {{ package_name }}
        """
        )
    )

    # Localize the local package path in the conda environment yaml files
    verbose = request.config.getoption("verbose")
    _snakemake(tmp_path, ["conda_localize"], verbose=verbose)

    return tmp_path

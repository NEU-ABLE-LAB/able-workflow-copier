# **Why `tox.ini` instead of `pyproject.toml`?**:
# Currently, `tox` only has partial support for `pyproject.toml` and
# cannot programmatically create a matrix of test environments.
# See https://tox.readthedocs.io/en/latest/config.html#pyproject-toml

[tox]
requires =
    tox>=4.25
    tox-gh-actions>=3.3.0
    tox-uv>=1.25.0
# If you get `ERROR: Package '*' requires a different Python:`
# Then install the desired version as a new conda environment, e.g., 3.12
# `conda create -n py312 python=3.12`
envlist = \
    py{311,312}-lint, \
    py{311,312}-package-unit-{core,runner}, \
    py{311,312}-typecheck-{core-runner}, \
    py{311,312}-workflow-rules, \
    py{311,312}-workflow-unit-{core,docs,runner,global}


[gh-actions]
python =
    3.11: py311
    3.12: py312


[testenv]
description = Generic test environment
package = editable
extras =
    core:
    runner: runner
dependency_groups = test
allowlist_externals = mkdir
setenv =
    PROJECT_NAME = {{ '{' }}{{ package_name }}{{ '}' }}
    COV_CORE_DATAFILE = {toxinidir}/.cover/.coverage.{envname}
    COVERAGE_FILE = {toxinidir}/.cover/.coverage.{envname}
    JUNIT_XML = {toxinidir}/.junit/junit.{envname}.xml
    PYTEST_PATHS = tests/
commands_pre =
    # Create .cover/ and .junit/ directories if they don't exist
    mkdir -p {toxinidir}/.cover
    mkdir -p {toxinidir}/.junit


[testenv:py{311,312}-lint]
description = Linting for core and each extras
package = skip
dependency_groups = lint
commands =
    {envpython} -m black --check --diff ./
    {envpython} -m ruff check --diff ./
    {envpython} -m snakefmt --config snakefmt.toml --check --diff workflow/


[testenv:py{311,312}-package-unit-{core,runner}]
description = pytest unit tests for package core and ETL runners that require additional dependencies.
setenv =
    {[testenv]setenv}
    PYTEST_PATHS = tests/{{ package_name }}/

    # Directory glob that should be *ignored* when we're *not* testing an extra
    core:   PYTEST_IGNORES = --ignore-glob '*/runner/*'

    # Re-run all the tests with the `runner` extra enabled, as well as the
    # tests that explicitly require the `runner` extra.
    runner: PYTEST_IGNORES =
commands =
    # The `-o addopts=''` option overrides the default `pyproject.toml` settings
    {envpython} -m pytest \
        --cov \
        --junitxml={env:JUNIT_XML} \
        -o junit_family=legacy \
        -o addopts='' \
        {posargs:} \
        {env:PYTEST_PATHS} \
        {env:PYTEST_IGNORES:}


[testenv:py{311,312}-typecheck-{core,runner}]
description = MyPy static type-checks for core and the runner extras
dependency_groups = typecheck
commands = {envpython} -m mypy


[testenv:py{311,312}-workflow-rules]
description = Snakemake rule integration tests. Requires network connection to build snakemake conda environment caches
package = skip
extras =
dependency_groups = workflow,test
setenv =
    {[testenv]setenv}
    PYTEST_PATHS = tests/workflow/rules/
commands_pre =
    {[testenv]commands_pre}
commands =
    {envpython} -m pytest \
        -o addopts='' \
        {posargs:} \
        {env:PYTEST_PATHS}


[testenv:py{311,312}-workflow-unit-{global,core,docs}]
description = Snakemake unit tests for workflow utilities and rule scripts that do not require a custom conda environment
package =
    core: editable
    docs: editable
    global: skip
    runner: editable
extras =
    core:
    docs: runner
    global:
    runner: runner
dependency_groups =
    # When snakemake uses `conda:` it injects `snakemake` as a dependency
    core: snakemake,test
    docs: snakemake,docs,test
    global: workflow,test
    runner: snakemake,runner,test
setenv =
    {[testenv]setenv}
	core: PYTEST_PATHS = tests/workflow/scripts/rules_conda_CORE/
	docs: PYTEST_PATHS = tests/workflow/scripts/rules_conda_DOCS/
    global: PYTEST_PATHS = tests/workflow/scripts/rules_global/
    runner: PYTEST_PATHS = tests/workflow/scripts/rules_RUNNER/
commands =
    # Workflow script unit tests
    # The `-o addopts=''` option overrides the default `pyproject.toml` settings
    {envpython} -m pytest \
        --cov \
        --junitxml={env:JUNIT_XML} \
        -o junit_family=legacy \
        -o addopts='' \
        {posargs:} \
        {env:PYTEST_PATHS}
